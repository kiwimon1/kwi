def bubble_sort(arr):
    n = len(arr)
    for i in range(n-1):                    
        for j in range(0, n-i-1):             
            if arr[j] > arr[j+1]:
                temp = arr[j]
                arr[j] = arr[j+1]
                arr[j+1] = temp         
 
numbers = [5, 3, 8, 1, 2]
bubble_sort(numbers)
print(numbers)
